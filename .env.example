# OpenAI API ключ (обязательно)
OPENAI_API_KEY=sk-...

# Redis URL
REDIS_URL=redis://redis:6379/0

# Папка для хранения файлов
STORAGE_PATH=/app/storage

# Максимальная длина видео в секундах (защита от злоупотреблений)
MAX_VIDEO_DURATION=3600

# Модель Whisper: tiny, base, small, medium, large-v3
WHISPER_MODEL=medium

# Язык транскрипции (ru, en, auto)
TRANSCRIPTION_LANGUAGE=auto

# Провайдер транскрипции: openai (default) или groq
# TRANSCRIPTION_PROVIDER=openai

# Groq API (быстрая альтернатива OpenAI Whisper)
# GROQ_API_KEY=gsk_...

# Провайдер AI-анализа: openai (default), gemini, ollama
# ANALYZER_PROVIDER=openai

# Google Gemini (бесплатная альтернатива для анализа)
# GEMINI_API_KEY=AIza...

# Максимальное количество шортсов с одного видео
MAX_SHORTS=7

# Минимальная длина шортса в секундах
MIN_SHORT_DURATION=30

# Максимальная длина шортса в секундах
MAX_SHORT_DURATION=90

# JWT авторизация
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=1440

# YouTube OAuth (для публикации)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok OAuth (для публикации)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Шифрование OAuth токенов (сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
OAUTH_ENCRYPTION_KEY=

# URL приложения (для OAuth redirect)
APP_BASE_URL=http://localhost

# Cloudflare R2 (опционально, если пусто — локальный диск)
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=streamcut
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Ollama (локальная модель для анализа)
# ANALYZER_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4

# Автоочистка файлов
CLEANUP_INTERVAL_HOURS=1
FILE_MAX_AGE_HOURS=24
