# ============================================================
# StreamCUT Production Environment Template
# ============================================================
# Copy this file to `.env` and fill in the placeholder values.
# DO NOT commit real API keys or secrets to version control.
# ============================================================

# ------------------------------------------------------------
# REQUIRED: Core Services
# ------------------------------------------------------------

# OpenAI API key (required). Starts with "sk-"
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE

# Redis connection URL. In Docker Compose use the service name.
REDIS_URL=redis://redis:6379/0

# Base path for all storage inside the container.
# Subdirectories (downloads, processed, temp, cache, footage_library) are auto-created.
STORAGE_PATH=/app/storage

# ------------------------------------------------------------
# Video Processing Settings
# ------------------------------------------------------------

# Maximum source video duration in seconds (default: 3600 = 1 hour)
MAX_VIDEO_DURATION=3600

# Maximum number of shorts to generate from one video (default: 7)
MAX_SHORTS=7

# Minimum short clip duration in seconds (default: 15)
MIN_SHORT_DURATION=15

# Maximum short clip duration in seconds (default: 60)
MAX_SHORT_DURATION=60

# Whisper model size: tiny, base, small, medium, large (default: medium)
WHISPER_MODEL=medium

# Transcription language: auto-detect or e.g. "en", "ru" (default: auto)
TRANSCRIPTION_LANGUAGE=auto

# ------------------------------------------------------------
# AI Provider Settings
# ------------------------------------------------------------

# Transcription provider: "openai" (default) or "groq"
TRANSCRIPTION_PROVIDER=openai

# Groq API key (optional). Required only if TRANSCRIPTION_PROVIDER=groq
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk-YOUR_GROQ_API_KEY_HERE

# Analyzer provider for moment detection: "openai" (default), "gemini", or "ollama"
ANALYZER_PROVIDER=openai

# Google Gemini API key (optional). Required only if ANALYZER_PROVIDER=gemini
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Ollama base URL for local LLM inference (optional).
# In Docker on Windows/Mac use host.docker.internal to reach the host machine.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Ollama model name (default: gemma4)
OLLAMA_MODEL=gemma4

# ------------------------------------------------------------
# Authentication & Security
# ------------------------------------------------------------

# ⚠️  WARNING: CHANGE THIS IMMEDIATELY!
# The default JWT secret was exposed in earlier commits.
# Generate a new one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_GENERATE_NEW_SECRET

# JWT token lifetime in minutes (default: 1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------

# Public base URL of the server (used for OAuth callbacks and file links).
# MUST match the address users access in their browser.
APP_BASE_URL=http://91.84.98.58

# How often the cleanup task runs in hours (default: 1)
CLEANUP_INTERVAL_HOURS=1

# How long processed files are kept before deletion in hours (default: 24)
FILE_MAX_AGE_HOURS=24

# ------------------------------------------------------------
# Cloud Storage: MinIO / S3-Compatible (preferred over legacy R2)
# ------------------------------------------------------------
# Leave empty to use local disk storage (processed files served via nginx /storage/).

MINIO_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=streamcut
MINIO_PUBLIC_URL=

# ------------------------------------------------------------
# Cloud Storage: Cloudflare R2 (legacy, optional)
# ------------------------------------------------------------
# R2 is superseded by MinIO/S3 settings above. Leave empty unless you need it.

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ------------------------------------------------------------
# OAuth: Direct Publishing (optional)
# ------------------------------------------------------------
# ⚠️  NOTE: YouTube and TikTok OAuth flows REQUIRE HTTPS to work.
# They will fail on plain HTTP deployments.

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Encryption key for storing OAuth tokens in Redis.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=
